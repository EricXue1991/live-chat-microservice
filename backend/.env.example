# LiveChat Backend Environment Variables

PORT=8080
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=             # LocalStack: http://localstack:4566

# PostgreSQL (users, rooms)
POSTGRES_DSN=postgres://livechat:livechat@localhost:5432/livechat?sslmode=disable

# Redis (cache, rate limiting, presence)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# Kafka (event stream, analytics)
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=livechat-events

# DynamoDB (messages, reactions)
DYNAMODB_MESSAGES_TABLE=livechat-messages
DYNAMODB_REACTIONS_TABLE=livechat-reactions

# S3 (attachments)
S3_BUCKET=livechat-attachments

# SNS/SQS (broadcast, reaction queue)
SNS_TOPIC_ARN=
SQS_REACTION_QUEUE_URL=
SQS_BROADCAST_QUEUE_URL=

# JWT
JWT_SECRET=your-secret-change-in-prod

# Feature flags
REACTION_MODE=async           # sync or async (experiment 3)
CACHE_ENABLED=true            # toggle Redis cache (experiment 5)
RATE_LIMIT_RPS=20             # per-user rate limit, 0=disabled (experiment 6)
